generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Link {
  id        String   @id @default(cuid())
  name      String
  url       String
  createdAt DateTime @default(now())
}

model Admin {
  id           Int      @id @default(1)
  passwordHash String
  updatedAt    DateTime @updatedAt
}
