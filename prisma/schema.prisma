generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Link {
  id            String          @id @default(cuid())
  name          String
  url           String
  apiUrl        String?
  isMaintenance Boolean         @default(false)
  createdAt     DateTime        @default(now())
  statusLogs    LinkStatusLog[]
}

model LinkStatusLog {
  id             String   @id @default(cuid())
  link           Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  linkId         String
  isUp           Boolean
  statusCode     Int?
  responseTimeMs Int?
  errorMessage   String?
  checkedAt      DateTime @default(now())

  @@index([linkId, checkedAt(sort: Desc)])
}

model Admin {
  id           Int      @id @default(1)
  passwordHash String
  updatedAt    DateTime @updatedAt
}

enum UserRole {
  ADMIN
  USER
  TECHNICIAN
}

/// Available permission keys:
/// - "ACCESS_CONTROL"  — manage persons, fingerprint devices, access logs, admin letters
/// - "DEVICE_IMPORT"   — import devices from CSV
model User {
  id            String         @id @default(cuid())
  userName      String         @unique
  fullName      String
  passwordHash  String
  role          UserRole       @default(USER)
  isActive      Boolean        @default(true)
  workshopId    String?
  workshop      Workshop?      @relation(fields: [workshopId], references: [id])
  permissions   Json           @default("[]")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  notifications Notification[]
}

model Department {
  id        String        @id @default(cuid())
  name      String        @unique
  divisions Division[]
  persons   AccessPerson[]
  createdAt DateTime      @default(now())
}

model Division {
  id           String     @id @default(cuid())
  name         String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  departmentId String
  units        Unit[]
  createdAt    DateTime   @default(now())

  @@unique([name, departmentId])
}

model Unit {
  id          String             @id @default(cuid())
  name        String
  division    Division           @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  divisionId  String
  assignments DeviceAssignment[]
  persons     AccessPerson[]
  createdAt   DateTime           @default(now())

  @@unique([name, divisionId])
}

model DeviceType {
  id         String     @id @default(cuid())
  name       String     @unique
  categories Category[]
  createdAt  DateTime   @default(now())
}

model Category {
  id           String     @id @default(cuid())
  name         String
  deviceType   DeviceType @relation(fields: [deviceTypeId], references: [id], onDelete: Cascade)
  deviceTypeId String
  isGlobal     Boolean    @default(false)
  devices      Device[]
  createdAt    DateTime   @default(now())

  @@unique([name, deviceTypeId])
}

enum DeviceNature {
  CONSUMABLE
  FIXED
}

model Device {
  id         String       @id @default(cuid())
  name       String?
  category   Category     @relation(fields: [categoryId], references: [id])
  categoryId String
  nature     DeviceNature @default(FIXED)
  notes      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  items      DeviceItem[]
}

enum DeviceItemStatus {
  AVAILABLE
  ASSIGNED
  DEFECTIVE
}

model DeviceItem {
  id                   String               @id @default(cuid())
  serialNumber         String               @unique
  device               Device               @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId             String
  status               DeviceItemStatus     @default(AVAILABLE)
  workshopId           String?
  workshop             Workshop?            @relation(fields: [workshopId], references: [id])
  assignment           DeviceAssignment?
  maintenanceRecords   MaintenanceRecord[]
  maintenanceRequests  MaintenanceRequest[]
  warrantyExpiry       DateTime?
  purchaseDate         DateTime?
  supplier             String?
  contractDetails      String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

model DeviceAssignment {
  id           String     @id @default(cuid())
  item         DeviceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId       String     @unique
  unit         Unit       @relation(fields: [unitId], references: [id])
  unitId       String
  recipientName String?
  assignedAt   DateTime   @default(now())
  returnedAt   DateTime?
}

model MaintenanceRecord {
  id              String           @id @default(cuid())
  item            DeviceItem       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId          String
  description     String
  technicianName  String
  status          MaintenanceStatus @default(OPEN)
  date            DateTime
  /// [{ "name": string, "quantity": number }, ...]
  partsUsed       Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  sparePartUsages SparePartUsage[]
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum DoorGroup {
  INSIDE
  OUTSIDE
}

enum DeviceSide {
  INSIDE
  OUTSIDE
}

enum FingerprintPersonType {
  EMPLOYEE
  RESIDENT
  OTHER
}

model FingerprintRecord {
  id         String                @id @default(cuid())
  personType FingerprintPersonType @default(EMPLOYEE)
  name       String
  personId   Int?
  region     String?
  note       String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  relatedId String?
  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt(sort: Desc)])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  userName  String
  action    String
  entity    String
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt(sort: Desc)])
}

enum MaintenanceRequestStatus {
  PENDING
  APPROVED
  ASSIGNED
  RESOLVED
  REJECTED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model MaintenanceRequest {
  id           String                   @id @default(cuid())
  deviceItem   DeviceItem               @relation(fields: [deviceItemId], references: [id], onDelete: Cascade)
  deviceItemId String
  description  String
  priority     MaintenancePriority      @default(MEDIUM)
  status       MaintenanceRequestStatus @default(PENDING)
  requestedBy  String
  approvedBy   String?
  assignedTo   String?
  workshopId   String?
  workshop     Workshop?                @relation(fields: [workshopId], references: [id])
  notes        String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([assignedTo, status])
}

model Workshop {
  id            String               @id @default(cuid())
  name          String               @unique
  users         User[]
  deviceItems   DeviceItem[]
  requests      MaintenanceRequest[]

  // Cross-workshop visibility (Self-relation)
  allowedToSee  Workshop[]           @relation("WorkshopVisibility")
  seenBy        Workshop[]           @relation("WorkshopVisibility")

  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model SparePart {
  id          String           @id @default(cuid())
  name        String           @unique
  partNumber  String?
  quantity    Int              @default(0)
  minQuantity Int              @default(5)
  category    String?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  usages      SparePartUsage[]
}

model SparePartUsage {
  id                String            @id @default(cuid())
  sparePart         SparePart         @relation(fields: [sparePartId], references: [id], onDelete: Cascade)
  sparePartId       String
  maintenanceRecord MaintenanceRecord @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)
  maintenanceId     String
  quantityUsed      Int
  usedAt            DateTime          @default(now())

  @@index([maintenanceId])
  @@index([sparePartId])
}

model AccessDoor {
  id           String     @id @default(cuid())
  name         String
  location     String?
  doorNumber   Int        @default(0)
  group        DoorGroup?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  devices      AccessDevice[]
  permissions  AccessPermission[]
  logs         AccessLog[]
  pendingOps   PendingDeviceOp[]
}

model AccessDevice {
  id           String     @id @default(cuid())
  door         AccessDoor @relation(fields: [doorId], references: [id], onDelete: Cascade)
  doorId       String
  name         String
  side         DeviceSide @default(INSIDE)
  serialNumber String?
  ipAddress    String?
  zkTerminalId Int?
  state        Int        @default(3)
  lastActivity DateTime?
  isAttendance Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([doorId])
}

model AccessPerson {
  id               String                @id @default(cuid())
  personType       FingerprintPersonType @default(EMPLOYEE)
  name             String
  personId         Int?
  empCode          String?
  zkEmployeeId     Int?
  identifier       String?               // External ID from source system (employee seq, resident id, HR code)
  region           String?
  note             String?
  dataWarning      String?               // Warning message for data quality issues (unclear door access, missing info, etc.)
  phone            String?
  accessType       String                @default("permanent")
  accessEndDate    DateTime?
  fingerprintStatus String                @default("none")
  faceStatus       String                @default("none")
  enrollDevice     String?
  lastSyncAt       DateTime?
  fingerprintTemplatesData Json?
  faceTemplatesData       Json?
  isActive         Boolean               @default(true)
  deletedAt        DateTime?             // Soft delete timestamp
  birthDate        DateTime?
  courtNumber      String?
  departmentId     String?
  unitId           String?
  address          String?
  hireDate         DateTime?
  role             String                @default("user")
  photoUrl         String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  permissions      AccessPermission[]
  logs             AccessLog[]
  pendingOps       PendingDeviceOp[]
  fingerprintTemplates FingerprintTemplate[]
  faceTemplates    FaceTemplate[]
  tempSchedules    UserTempSchedule[]
  department       Department?           @relation(fields: [departmentId], references: [id])
  unit             Unit?                 @relation(fields: [unitId], references: [id])

  @@index([identifier])
}

model AccessPermission {
  id        String       @id @default(cuid())
  person    AccessPerson @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId  String
  door      AccessDoor   @relation(fields: [doorId], references: [id], onDelete: Cascade)
  doorId    String
  grantedBy String?
  grantedAt DateTime     @default(now())

  @@unique([personId, doorId])
}

model AccessLog {
  id              String        @id @default(cuid())
  person          AccessPerson? @relation(fields: [personId], references: [id], onDelete: SetNull)
  personId        String?
  door            AccessDoor    @relation(fields: [doorId], references: [id], onDelete: Cascade)
  doorId          String
  punchTime       DateTime
  punchState      Int           @default(0)
  verifyType      Int?
  status          String        @default("authorized")
  syncedFromZKBio Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@unique([doorId, punchTime])
  @@index([personId, punchTime(sort: Desc)])
}

model PendingDeviceOp {
  id          String   @id @default(cuid())
  personId    String
  personName  String
  type        String   // "block", "push", "update"
  doorId      String
  doorName    String
  doorIp      String
  uid         Int
  empCode     String   @default("")
  status      String   @default("pending") // pending, in_progress, success, failed
  retries     Int      @default(0)
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  person      AccessPerson @relation(fields: [personId], references: [id], onDelete: Cascade)
  door        AccessDoor   @relation(fields: [doorId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

model FingerprintTemplate {
  id               String   @id @default(cuid())
  person           AccessPerson @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId         String
  zktecoUserId     Int
  fingerIndex      Int
  valid            Int      @default(1)
  templateData     String   @db.Text
  templateSize     Int?
  templateHash     String?
  zktecoTemplateId Int?
  source           String   @default("migration")
  createdAt        DateTime @default(now())

  @@unique([personId, fingerIndex])
  @@index([zktecoUserId])
  @@index([templateHash])
}

model FaceTemplate {
  id               String   @id @default(cuid())
  person           AccessPerson @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId         String
  zktecoUserId     Int
  faceIndex        Int      @default(0)
  valid            Int      @default(1)
  templateData     String   @db.Text
  templateSize     Int?
  templateHash     String?
  zktecoTemplateId Int?
  source           String   @default("migration")
  createdAt        DateTime @default(now())

  @@unique([personId, faceIndex])
  @@index([zktecoUserId])
}

model ShiftClass {
  id              String   @id @default(cuid())
  zktecoSchClassId Int     @unique
  name            String
  startTime       DateTime
  endTime         DateTime
  lateMinutes     Int      @default(0)
  earlyMinutes    Int      @default(0)
  checkIn         Boolean  @default(true)
  checkOut        Boolean  @default(true)
  workDay         Float    @default(1.0)
  color           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  schedules       UserTempSchedule[]
}

model UserTempSchedule {
  id              String     @id @default(cuid())
  person          AccessPerson @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId        String
  shiftClass      ShiftClass? @relation(fields: [shiftClassId], references: [id], onDelete: SetNull)
  shiftClassId    String?
  comeTime        DateTime
  leaveTime       DateTime
  scheduleType    Int        @default(0)
  flag            Int        @default(1)
  overtime        Boolean    @default(false)
  zktecoSchClassId Int?
  createdAt       DateTime   @default(now())

  @@index([personId, comeTime])
  @@index([comeTime])
}

model AdminLetter {
  id               String              @id @default(cuid())
  title            String
  referenceNumber  String?
  letterDate       DateTime
  pdfPath          String
  originalFileName String
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  persons          AdminLetterPerson[]

  @@index([letterDate(sort: Desc)])
}

model AdminLetterPerson {
  id         String                @id @default(cuid())
  letter     AdminLetter           @relation(fields: [letterId], references: [id], onDelete: Cascade)
  letterId   String
  personType FingerprintPersonType @default(EMPLOYEE)
  personName String
  personId   Int?
  note       String?
  createdAt  DateTime              @default(now())

  @@index([letterId])
  @@index([personType, personId])
}
