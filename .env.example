# Copy to .env and set your PostgreSQL credentials
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/redirect_db"

# Admin password (stored hashed in DB). Used to create the first admin if table is empty.
ADMIN_INITIAL_PASSWORD="Moh@9801"

# Optional: comma-separated browser origins (omit for dev — Nest reflects the request Origin)
# CORS_ORIGIN=http://localhost:4000,http://127.0.0.1:4000
